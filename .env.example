# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# === Preferred: Firebase auto-refresh credentials ===
# Read both values once from a logged-in browser session: open DevTools →
# Application → Local Storage → https://myaidrive.com → key
#   firebase:authUser:<API_KEY>:[DEFAULT]
# - apiKey                       → AIDRIVE_FIREBASE_API_KEY
# - stsTokenManager.refreshToken → AIDRIVE_REFRESH_TOKEN
#
# Refresh tokens are long-lived; the uploader mints fresh access JWTs as
# needed via Google's secure-token endpoint. AIDRIVE_TOKEN below is then
# unused.
AIDRIVE_REFRESH_TOKEN=
AIDRIVE_FIREBASE_API_KEY=

# === Optional fallback: manually-pasted bearer JWT ===
# Only needed when the Firebase refresh credentials above are not set.
# This is a short-lived JWT from the same DevTools session
# (stsTokenManager.accessToken). It will stop working after ~1 hour.
AIDRIVE_TOKEN=

# Optional: path to an external file holding the AI Drive JWT (manual
# fallback only). When set, the token is reloaded from this file before
# every API request. Ignored once Firebase auto-refresh is active.
# AIDRIVE_TOKEN_FILE=/run/secrets/aidrive_token

# Optional: path to the historical-mode checkpoint file used to resume an
# interrupted backfill. Default ".backfill_checkpoint.json" in the working
# directory. The file is gitignored — never commit it.
# CHECKPOINT_FILE=.backfill_checkpoint.json

# Gmail OAuth credentials (see get_gmail_token.py).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
