# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# AI Drive Bearer JWT (copy from your AI Drive browser session).
# WARNING: this JWT may expire (typically every few hours). When AI Drive
# starts returning HTTP 401 / AUTH_REQUIRED / "invalid token", refresh it
# from the browser and update this value, then re-run. Historical mode
# resumes from the checkpoint file, so no progress is lost.
AIDRIVE_TOKEN=put_your_token_here

# Optional: path to an external file holding the AI Drive JWT. When set,
# the token is reloaded from this file before every API request, so an
# operator can drop in a refreshed JWT mid-run without restarting the
# process. The file must contain only the raw token (no Bearer prefix).
# AIDRIVE_TOKEN_FILE=/run/secrets/aidrive_token

# Optional: path to the historical-mode checkpoint file used to resume an
# interrupted backfill. Default ".backfill_checkpoint.json" in the working
# directory. The file is gitignored — never commit it.
# CHECKPOINT_FILE=.backfill_checkpoint.json

# Gmail OAuth credentials (see get_gmail_token.py).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
