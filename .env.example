# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# AI Drive Bearer JWT (copy from your AI Drive browser session).
# WARNING: this JWT may expire; refresh it from the browser if API calls
# start returning 401/403.
AIDRIVE_TOKEN=put_your_token_here

# Gmail OAuth credentials (see get_gmail_token.py).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
